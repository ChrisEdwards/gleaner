#!/usr/bin/env bash
set -euo pipefail

# --- Constants ---
GLEAN_VERSION="$(cat "$(dirname "$(readlink -f "$0" 2>/dev/null || realpath "$0" 2>/dev/null || echo "$0")")/VERSION" 2>/dev/null || echo "0.1.0")"
DEFAULT_OUTPUT_DIR="./gleanings"
DEFAULT_MODEL="opus"
DEFAULT_EFFORT="high"
DEFAULT_WORKERS=3
DEFAULT_MAX_REPOS=10
MAX_CRITIQUE_PASSES=8
CLONE_DIR="/tmp/glean"

# --- Globals (set by parse_args) ---
SPEC_FILE=""
OUTPUT_DIR="$DEFAULT_OUTPUT_DIR"
CONTINUE_MODE=false
MODEL="$DEFAULT_MODEL"
EFFORT="$DEFAULT_EFFORT"
WORKERS="$DEFAULT_WORKERS"
MAX_REPOS="$DEFAULT_MAX_REPOS"
GREENFIELD=false
VERBOSE=false
PRESEEDED_REPOS=()
BASE_SESSION_ID=""

# --- Functions ---

check_dependencies() {
    local missing=()
    command -v claude >/dev/null 2>&1 || missing+=("claude")
    command -v git >/dev/null 2>&1    || missing+=("git")
    command -v jq >/dev/null 2>&1     || missing+=("jq")

    if [[ ${#missing[@]} -gt 0 ]]; then
        echo "glean: missing required dependencies: ${missing[*]}" >&2
        echo "Install them and try again." >&2
        return 3
    fi

    # Check bash version
    if [[ "${BASH_VERSINFO[0]}" -lt 4 ]]; then
        echo "glean: requires bash 4.0+, found $BASH_VERSION" >&2
        return 3
    fi
    return 0
}

usage() {
    cat <<'USAGE'
Usage: glean [options] <spec-file>

Automated spec enhancement through open source intelligence.

Arguments:
  spec-file                    Path to the design spec (required)

Options:
  --continue                   Resume after human checkpoint or interruption
  --output-dir <dir>           Output directory (default: ./gleanings)
  --repos <urls...>            Pre-seed specific repo URLs (skips discovery)
  --max-repos <n>              Maximum repos to deep-dive (default: 10)
  --model <model>              Claude model (default: opus)
  --effort <level>             Thinking effort: medium, high, max (default: high)
  --workers <n>                Parallel repo analyses (default: 3)
  --greenfield                 Forbid reading local codebase during analysis
  --verbose                    Stream Claude output to terminal
  --help                       Show this help message
  --version                    Show version
USAGE
}

parse_args() {
    # Reset globals to defaults
    SPEC_FILE=""
    OUTPUT_DIR="$DEFAULT_OUTPUT_DIR"
    CONTINUE_MODE=false
    MODEL="$DEFAULT_MODEL"
    EFFORT="$DEFAULT_EFFORT"
    WORKERS="$DEFAULT_WORKERS"
    MAX_REPOS="$DEFAULT_MAX_REPOS"
    GREENFIELD=false
    VERBOSE=false
    PRESEEDED_REPOS=()

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --help|-h)
                usage
                exit 0
                ;;
            --version)
                echo "glean $GLEAN_VERSION"
                exit 0
                ;;
            --continue)
                CONTINUE_MODE=true
                shift
                ;;
            --output-dir)
                [[ $# -lt 2 ]] && { echo "glean: --output-dir requires a value" >&2; return 2; }
                OUTPUT_DIR="$2"
                shift 2
                ;;
            --repos)
                shift
                while [[ $# -gt 0 && ! "$1" =~ ^-- && "$1" =~ :// ]]; do
                    PRESEEDED_REPOS+=("$1")
                    shift
                done
                ;;
            --max-repos)
                [[ $# -lt 2 ]] && { echo "glean: --max-repos requires a value" >&2; return 2; }
                MAX_REPOS="$2"
                shift 2
                ;;
            --model)
                [[ $# -lt 2 ]] && { echo "glean: --model requires a value" >&2; return 2; }
                MODEL="$2"
                shift 2
                ;;
            --effort)
                [[ $# -lt 2 ]] && { echo "glean: --effort requires a value" >&2; return 2; }
                EFFORT="$2"
                shift 2
                ;;
            --workers)
                [[ $# -lt 2 ]] && { echo "glean: --workers requires a value" >&2; return 2; }
                WORKERS="$2"
                shift 2
                ;;
            --greenfield)
                GREENFIELD=true
                shift
                ;;
            --verbose)
                VERBOSE=true
                shift
                ;;
            --*)
                echo "glean: unknown option: $1" >&2
                return 2
                ;;
            *)
                if [[ -z "$SPEC_FILE" ]]; then
                    SPEC_FILE="$1"
                else
                    echo "glean: unexpected argument: $1" >&2
                    return 2
                fi
                shift
                ;;
        esac
    done

    if [[ -z "$SPEC_FILE" ]]; then
        echo "glean: spec file is required" >&2
        return 2
    fi
}

setup_logging() {
    mkdir -p "$OUTPUT_DIR/.logs"
    touch "$OUTPUT_DIR/.logs/glean.log"
}

log_info() {
    local msg="$1"
    local timestamp
    timestamp="$(date '+%Y-%m-%d %H:%M:%S')"
    echo "[$timestamp] INFO: $msg" >> "$OUTPUT_DIR/.logs/glean.log"
    if [[ "$VERBOSE" == "true" ]]; then
        echo "[$timestamp] INFO: $msg" >&2
    fi
}

log_error() {
    local msg="$1"
    local timestamp
    timestamp="$(date '+%Y-%m-%d %H:%M:%S')"
    echo "[$timestamp] ERROR: $msg" >> "$OUTPUT_DIR/.logs/glean.log"
    echo "glean: $msg" >&2
}

log_session() {
    local name="$1" content="$2"
    echo "$content" >> "$OUTPUT_DIR/.logs/${name}.log"
}

save_state() {
    local phase="$1"
    local discovery_session_id="${2:-}"

    # Read existing repos state if file exists, otherwise empty object
    local repos_json="{}"
    if [[ -f "$OUTPUT_DIR/.glean-state.json" ]]; then
        repos_json=$(jq -r '.repos // {}' "$OUTPUT_DIR/.glean-state.json")
    fi

    jq -n \
        --arg base "$BASE_SESSION_ID" \
        --arg spec "$SPEC_FILE" \
        --arg phase "$phase" \
        --arg disc "$discovery_session_id" \
        --argjson repos "$repos_json" \
        '{
            base_session_id: $base,
            spec_file: $spec,
            phase: $phase,
            discovery_session_id: $disc,
            repos: $repos,
            synthesis: "pending"
        }' > "$OUTPUT_DIR/.glean-state.json"
}

load_state_field() {
    local field="$1"
    jq -r "$field" "$OUTPUT_DIR/.glean-state.json"
}

update_repo_state() {
    local repo_name="$1" status="$2" session_id="$3" step="$4" critique_passes="$5"

    local tmp
    tmp=$(mktemp)
    jq \
        --arg repo "$repo_name" \
        --arg status "$status" \
        --arg sess "$session_id" \
        --arg step "$step" \
        --argjson passes "$critique_passes" \
        '.repos[$repo] = {status: $status, session_id: $sess, step: $step, critique_passes: $passes}' \
        "$OUTPUT_DIR/.glean-state.json" > "$tmp"
    mv "$tmp" "$OUTPUT_DIR/.glean-state.json"
}

extract_github_urls() {
    local file="$1"
    grep -oE 'https?://github\.com/[A-Za-z0-9._-]+/[A-Za-z0-9._-]+' "$file" 2>/dev/null \
        | sed 's/[[:punct:]]*$//' \
        | sort -u \
        || true
}

repo_name_from_url() {
    local url="$1"
    echo "$url" | sed 's|.*/\([^/]*/[^/]*\)$|\1|' | sed 's|\.git$||'
}

repo_short_name() {
    local repo_name="$1"
    echo "$repo_name" | cut -d'/' -f2
}

run_claude_session() {
    local prompt="$1"
    local allowed_tools="${2:-}"
    local extra_args=("${@:3}")

    local cmd=(claude -p "$prompt"
        --model "$MODEL" --effort "$EFFORT"
        --output-format json
        --permission-mode bypassPermissions)

    if [[ -n "$allowed_tools" ]]; then
        cmd+=(--allowedTools "$allowed_tools")
    fi
    cmd+=("${extra_args[@]}")

    local output
    if [[ "$VERBOSE" == "true" ]]; then
        output=$("${cmd[@]}" 2>&2)
    else
        output=$("${cmd[@]}" 2>/dev/null)
    fi

    echo "$output" | jq -r '.session_id'
}

run_claude_fork() {
    local base_session="$1" prompt="$2"
    local allowed_tools="${3:-}"
    local extra_args=("${@:4}")

    local cmd=(claude -p "$prompt"
        --resume "$base_session" --fork-session
        --model "$MODEL" --effort "$EFFORT"
        --output-format json
        --permission-mode bypassPermissions)

    if [[ -n "$allowed_tools" ]]; then
        cmd+=(--allowedTools "$allowed_tools")
    fi
    cmd+=("${extra_args[@]}")

    local output
    if [[ "$VERBOSE" == "true" ]]; then
        output=$("${cmd[@]}" 2>&2)
    else
        output=$("${cmd[@]}" 2>/dev/null)
    fi

    echo "$output" | jq -r '.session_id'
}

run_claude_resume() {
    local session_id="$1" prompt="$2"
    local allowed_tools="${3:-}"
    local extra_args=("${@:4}")

    local cmd=(claude -p "$prompt"
        --resume "$session_id"
        --model "$MODEL" --effort "$EFFORT"
        --output-format json
        --permission-mode bypassPermissions)

    if [[ -n "$allowed_tools" ]]; then
        cmd+=(--allowedTools "$allowed_tools")
    fi
    cmd+=("${extra_args[@]}")

    local output
    if [[ "$VERBOSE" == "true" ]]; then
        output=$("${cmd[@]}" 2>&2)
    else
        output=$("${cmd[@]}" 2>/dev/null)
    fi

    echo "$output" | jq -r '.result'
}

create_base_session() {
    local spec_path="$1"

    if [[ ! -f "$spec_path" ]]; then
        log_error "spec file not found: $spec_path"
        return 2
    fi

    log_info "Phase 1: Reading spec file..."
    local prompt
    prompt="Read this spec and confirm you understand the key domains, constraints, and goals.

$(cat "$spec_path")"

    local session_id
    session_id=$(run_claude_session "$prompt")

    if [[ -z "$session_id" || "$session_id" == "null" ]]; then
        log_error "Failed to create base session"
        return 1
    fi

    BASE_SESSION_ID="$session_id"
    log_info "Base session created: $BASE_SESSION_ID"
    echo "$session_id"
}

main() {
    if [[ $# -eq 0 ]]; then
        usage
        exit 2
    fi

    # Handle --help and --version before parse_args for early exit
    case "${1:-}" in
        --help|-h) usage; exit 0 ;;
        --version) echo "glean $GLEAN_VERSION"; exit 0 ;;
    esac

    parse_args "$@"
    check_dependencies || exit $?

    echo "glean: pipeline not yet implemented" >&2
    exit 1
}

[[ "${BASH_SOURCE[0]}" == "${0}" ]] && main "$@" || true
