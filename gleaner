#!/usr/bin/env bash
set -euo pipefail

# --- Constants ---
_gleaner_dir() {
    local dir
    dir="$(dirname "$(readlink -f "$0" 2>/dev/null || realpath "$0" 2>/dev/null || echo "$0")")"
    echo "$dir"
}

GLEANER_VERSION="$(cat "$(_gleaner_dir)/VERSION" 2>/dev/null || cat "$(_gleaner_dir)/.gleaner-version" 2>/dev/null || echo "0.1.0")"
DEFAULT_OUTPUT_DIR="./gleanings"
DEFAULT_MODEL="opus"
DEFAULT_EFFORT="high"
DEFAULT_WORKERS=3
DEFAULT_MAX_REPOS=10
MAX_CRITIQUE_PASSES=8
CLONE_DIR="/tmp/gleaner"

# --- Globals (set by parse_args) ---
SPEC_FILE=""
OUTPUT_DIR="$DEFAULT_OUTPUT_DIR"
CONTINUE_MODE=false
MODEL="$DEFAULT_MODEL"
EFFORT="$DEFAULT_EFFORT"
WORKERS="$DEFAULT_WORKERS"
MAX_REPOS="$DEFAULT_MAX_REPOS"
GREENFIELD=false
VERBOSE=false
PRESEEDED_REPOS=()
BASE_SESSION_ID=""

# --- Functions ---

check_dependencies() {
    local missing=()
    command -v claude >/dev/null 2>&1 || missing+=("claude")
    command -v git >/dev/null 2>&1    || missing+=("git")
    command -v jq >/dev/null 2>&1     || missing+=("jq")

    if [[ ${#missing[@]} -gt 0 ]]; then
        echo "gleaner: missing required dependencies: ${missing[*]}" >&2
        echo "Install them and try again." >&2
        return 3
    fi

    # Check bash version
    if [[ "${BASH_VERSINFO[0]}" -lt 4 ]]; then
        echo "gleaner: requires bash 4.0+, found $BASH_VERSION" >&2
        return 3
    fi
    return 0
}

usage() {
    cat <<'USAGE'
Usage: gleaner [options] <spec-file>

Automated spec enhancement through open source intelligence.

Arguments:
  spec-file                    Path to the design spec (required)

Options:
  --continue                   Resume after human checkpoint or interruption
  --output-dir <dir>           Output directory (default: ./gleanings)
  --repos <urls...>            Pre-seed specific repo URLs (skips discovery)
  --max-repos <n>              Maximum repos to deep-dive (default: 10)
  --model <model>              Claude model (default: opus)
  --effort <level>             Thinking effort: medium, high, max (default: high)
  --workers <n>                Parallel repo analyses (default: 3)
  --greenfield                 Forbid reading local codebase during analysis
  --verbose                    Stream Claude output to terminal
  --help                       Show this help message
  --version                    Show version
USAGE
}

parse_args() {
    # Reset globals to defaults
    SPEC_FILE=""
    OUTPUT_DIR="$DEFAULT_OUTPUT_DIR"
    CONTINUE_MODE=false
    MODEL="$DEFAULT_MODEL"
    EFFORT="$DEFAULT_EFFORT"
    WORKERS="$DEFAULT_WORKERS"
    MAX_REPOS="$DEFAULT_MAX_REPOS"
    GREENFIELD=false
    VERBOSE=false
    PRESEEDED_REPOS=()

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --help|-h)
                usage
                exit 0
                ;;
            --version)
                echo "gleaner $GLEANER_VERSION"
                exit 0
                ;;
            --continue)
                CONTINUE_MODE=true
                shift
                ;;
            --output-dir)
                [[ $# -lt 2 ]] && { echo "gleaner: --output-dir requires a value" >&2; return 2; }
                OUTPUT_DIR="$2"
                shift 2
                ;;
            --repos)
                shift
                while [[ $# -gt 0 && ! "$1" =~ ^-- && "$1" =~ :// ]]; do
                    PRESEEDED_REPOS+=("$1")
                    shift
                done
                ;;
            --max-repos)
                [[ $# -lt 2 ]] && { echo "gleaner: --max-repos requires a value" >&2; return 2; }
                MAX_REPOS="$2"
                shift 2
                ;;
            --model)
                [[ $# -lt 2 ]] && { echo "gleaner: --model requires a value" >&2; return 2; }
                MODEL="$2"
                shift 2
                ;;
            --effort)
                [[ $# -lt 2 ]] && { echo "gleaner: --effort requires a value" >&2; return 2; }
                EFFORT="$2"
                shift 2
                ;;
            --workers)
                [[ $# -lt 2 ]] && { echo "gleaner: --workers requires a value" >&2; return 2; }
                WORKERS="$2"
                shift 2
                ;;
            --greenfield)
                GREENFIELD=true
                shift
                ;;
            --verbose)
                VERBOSE=true
                shift
                ;;
            --*)
                echo "gleaner: unknown option: $1" >&2
                return 2
                ;;
            *)
                if [[ -z "$SPEC_FILE" ]]; then
                    SPEC_FILE="$1"
                else
                    echo "gleaner: unexpected argument: $1" >&2
                    return 2
                fi
                shift
                ;;
        esac
    done

    if [[ -z "$SPEC_FILE" ]]; then
        echo "gleaner: spec file is required" >&2
        return 2
    fi
}

setup_logging() {
    mkdir -p "$OUTPUT_DIR/.logs"
    touch "$OUTPUT_DIR/.logs/gleaner.log"
}

log_info() {
    local msg="$1"
    local timestamp
    timestamp="$(date '+%Y-%m-%d %H:%M:%S')"
    echo "[$timestamp] INFO: $msg" >> "$OUTPUT_DIR/.logs/gleaner.log"
    if [[ "$VERBOSE" == "true" ]]; then
        echo "[$timestamp] INFO: $msg" >&2
    fi
}

log_status() {
    local msg="$1"
    local timestamp
    timestamp="$(date '+%Y-%m-%d %H:%M:%S')"
    echo "[$timestamp] INFO: $msg" >> "$OUTPUT_DIR/.logs/gleaner.log"
    echo "==> $msg" >&2
}

log_error() {
    local msg="$1"
    local timestamp
    timestamp="$(date '+%Y-%m-%d %H:%M:%S')"
    echo "[$timestamp] ERROR: $msg" >> "$OUTPUT_DIR/.logs/gleaner.log"
    echo "gleaner: $msg" >&2
}

log_session() {
    local name="$1" content="$2"
    echo "$content" >> "$OUTPUT_DIR/.logs/${name}.log"
}

save_state() {
    local phase="$1"
    local discovery_session_id="${2:-}"

    # Read existing repos state if file exists, otherwise empty object
    local repos_json="{}"
    if [[ -f "$OUTPUT_DIR/.gleaner-state.json" ]]; then
        repos_json=$(jq -r '.repos // {}' "$OUTPUT_DIR/.gleaner-state.json")
    fi

    jq -n \
        --arg base "$BASE_SESSION_ID" \
        --arg spec "$SPEC_FILE" \
        --arg phase "$phase" \
        --arg disc "$discovery_session_id" \
        --argjson repos "$repos_json" \
        '{
            base_session_id: $base,
            spec_file: $spec,
            phase: $phase,
            discovery_session_id: $disc,
            repos: $repos,
            synthesis: "pending"
        }' > "$OUTPUT_DIR/.gleaner-state.json"
}

load_state_field() {
    local field="$1"
    jq -r "$field" "$OUTPUT_DIR/.gleaner-state.json"
}

update_repo_state() {
    local repo_name="$1" status="$2" session_id="$3" step="$4" critique_passes="$5"
    local critique_session_id="${6:-}"
    local lockdir="$OUTPUT_DIR/.gleaner-state.lock"

    # Acquire lock (mkdir is atomic on POSIX filesystems)
    local retries=0
    while ! mkdir "$lockdir" 2>/dev/null; do
        retries=$((retries + 1))
        [[ $retries -gt 50 ]] && { log_error "update_repo_state: timeout waiting for lock"; return 1; }
        sleep 0.1
    done

    local tmp rc
    tmp=$(mktemp)
    if jq \
        --arg repo "$repo_name" \
        --arg status "$status" \
        --arg sess "$session_id" \
        --arg step "$step" \
        --argjson passes "$critique_passes" \
        --arg csess "$critique_session_id" \
        '.repos[$repo] = {status: $status, session_id: $sess, step: $step, critique_passes: $passes, critique_session_id: $csess}' \
        "$OUTPUT_DIR/.gleaner-state.json" > "$tmp" && mv "$tmp" "$OUTPUT_DIR/.gleaner-state.json"; then
        rc=0
    else
        rc=1
    fi
    rmdir "$lockdir"
    return $rc
}

extract_github_urls() {
    local file="$1"
    grep -oE 'https?://github\.com/[A-Za-z0-9._-]+/[A-Za-z0-9._-]+' "$file" 2>/dev/null \
        | sed 's/[[:punct:]]*$//' \
        | sort -u \
        || true
}

repo_name_from_url() {
    local url="$1"
    echo "$url" | sed 's|.*/\([^/]*/[^/]*\)$|\1|' | sed 's|\.git$||'
}

repo_short_name() {
    local repo_name="$1"
    echo "$repo_name" | cut -d'/' -f2
}

run_claude_session() {
    local prompt="$1"
    local allowed_tools="${2:-}"
    local extra_args=("${@:3}")

    local cmd=(claude -p "$prompt"
        --model "$MODEL" --effort "$EFFORT"
        --output-format json
        --permission-mode bypassPermissions)

    if [[ -n "$allowed_tools" ]]; then
        cmd+=(--allowedTools "$allowed_tools")
    fi
    cmd+=("${extra_args[@]}")

    local output
    if [[ "$VERBOSE" == "true" ]]; then
        output=$("${cmd[@]}" 2>&2)
    else
        output=$("${cmd[@]}" 2>/dev/null)
    fi

    echo "$output" | jq -r '.session_id'
}

run_claude_fork() {
    local base_session="$1" prompt="$2"
    local allowed_tools="${3:-}"
    local extra_args=("${@:4}")

    local cmd=(claude -p "$prompt"
        --resume "$base_session" --fork-session
        --model "$MODEL" --effort "$EFFORT"
        --output-format json
        --permission-mode bypassPermissions)

    if [[ -n "$allowed_tools" ]]; then
        cmd+=(--allowedTools "$allowed_tools")
    fi
    cmd+=("${extra_args[@]}")

    local output
    if [[ "$VERBOSE" == "true" ]]; then
        output=$("${cmd[@]}" 2>&2)
    else
        output=$("${cmd[@]}" 2>/dev/null)
    fi

    echo "$output" | jq -r '.session_id'
}

run_claude_resume() {
    local session_id="$1" prompt="$2"
    local allowed_tools="${3:-}"
    local extra_args=("${@:4}")

    local cmd=(claude -p "$prompt"
        --resume "$session_id"
        --model "$MODEL" --effort "$EFFORT"
        --output-format json
        --permission-mode bypassPermissions)

    if [[ -n "$allowed_tools" ]]; then
        cmd+=(--allowedTools "$allowed_tools")
    fi
    cmd+=("${extra_args[@]}")

    local output
    if [[ "$VERBOSE" == "true" ]]; then
        output=$("${cmd[@]}" 2>&2)
    else
        output=$("${cmd[@]}" 2>/dev/null)
    fi

    echo "$output" | jq -r '.result'
}

create_base_session() {
    local spec_path="$1"

    if [[ ! -f "$spec_path" ]]; then
        log_error "spec file not found: $spec_path"
        return 2
    fi

    log_status "Phase 1/5: Ingesting spec..."
    local prompt
    prompt="Read this spec and confirm you understand the key domains, constraints, and goals.

$(cat "$spec_path")"

    local session_id
    session_id=$(run_claude_session "$prompt")

    if [[ -z "$session_id" || "$session_id" == "null" ]]; then
        log_error "Failed to create base session"
        return 1
    fi

    BASE_SESSION_ID="$session_id"
    log_status "Spec ingested (session: $BASE_SESSION_ID)"
    echo "$session_id"
}

build_discovery_prompt() {
    cat <<EOF
Search the web and GitHub for open source projects that have useful
solutions, architectural patterns, or lessons learned relevant to the
spec you just read. Look across the key problem domains the spec
addresses. Dig deep. Find projects that can deliver powerful
lessons-learned.

Write your findings to ${OUTPUT_DIR}/reference-projects.md with a
description of each project and why it is relevant. Include the
GitHub URL for each project.
EOF
}

run_discovery() {
    log_status "Phase 2/5: Discovering relevant open source projects..."

    local prompt
    prompt=$(build_discovery_prompt)

    local allowed_tools="Read,Bash,WebSearch,WebFetch,Glob,Grep,Write,Agent"
    local session_id
    session_id=$(run_claude_fork "$BASE_SESSION_ID" "$prompt" "$allowed_tools")

    if [[ -z "$session_id" || "$session_id" == "null" ]]; then
        log_error "Discovery session failed"
        return 1
    fi

    log_status "Discovery complete"
    save_state "checkpoint" "$session_id"

    if [[ ! -f "$OUTPUT_DIR/reference-projects.md" ]]; then
        log_error "Discovery did not produce reference-projects.md"
        return 1
    fi

    echo "$session_id"
}

human_checkpoint() {
    save_state "checkpoint" ""
    echo ""
    echo "Discovery complete. Review and edit:"
    echo "  $OUTPUT_DIR/reference-projects.md"
    echo ""
    echo "Add or remove repos as needed, then re-run:"
    echo "  gleaner --continue $SPEC_FILE"
    echo ""
    exit 10
}

is_cosmetic() {
    local response="$1"
    if echo "$response" | grep -qi 'cosmetic'; then
        echo "true"
    else
        echo "false"
    fi
}

greenfield_suffix() {
    if [[ "$GREENFIELD" == "true" ]]; then
        echo "

Do not read my existing code. I want greenfield analysis."
    fi
}

build_initial_analysis_prompt() {
    local repo_path="$1" output_path="$2" spec_name="$3"
    cat <<EOF
Investigate the repo at ${repo_path} and look for useful ideas that
can be reimagined in highly accretive ways on top of existing
${spec_name} primitives.

Write your analysis to ${output_path}.$(greenfield_suffix)
EOF
}

build_deep_analysis_prompt() {
    local output_path="$1"
    cat <<EOF
You barely scratched the surface here. You must go way deeper and
think more profoundly and with more ambition and boldness.

Revise ${output_path}.$(greenfield_suffix)
EOF
}

build_inversion_prompt() {
    local repo_name="$1" output_path="$2"
    cat <<EOF
Now invert the analysis: what are things that we can do because we
are starting with "correct by design/structure" primitives that
${repo_name} simply could never do?

Append a new section to ${output_path}.$(greenfield_suffix)
EOF
}

build_first_critique_prompt() {
    local output_path="$1"
    cat <<EOF
Read the analysis at ${output_path}, then examine the repo to verify
its claims. Look for blunders, mistakes, misconceptions, logical flaws,
errors of omission, oversights, sloppy thinking, etc. and make revisions.

After making revisions, state whether your changes were SUBSTANTIVE
(restructured arguments, added missing insights, corrected errors)
or COSMETIC (wording, formatting, minor clarifications).
EOF
}

build_critique_prompt() {
    cat <<'EOF'
Look over everything in the analysis for blunders, mistakes,
misconceptions, logical flaws, errors of omission, oversights,
sloppy thinking, etc. and make revisions.

After making revisions, state whether your changes were SUBSTANTIVE
(restructured arguments, added missing insights, corrected errors)
or COSMETIC (wording, formatting, minor clarifications).
EOF
}

clone_repo() {
    local url="$1" target_dir="$2"
    log_info "Cloning $url to $target_dir..."
    if ! git clone --depth 1 "$url" "$target_dir" 2>/dev/null; then
        log_error "Failed to clone $url"
        return 1
    fi
}

cleanup_repo() {
    local target_dir="$1"
    [[ -d "$target_dir" ]] && rm -rf "$target_dir"
}

analyze_repo() {
    local repo_url="$1"
    local repo_name
    repo_name=$(repo_name_from_url "$repo_url")
    local short_name
    short_name=$(repo_short_name "$repo_name")
    local clone_path="$CLONE_DIR/$short_name"
    local output_path="$OUTPUT_DIR/analysis-${short_name}.md"
    local spec_name
    spec_name=$(basename "$SPEC_FILE" .md)

    local analysis_tools="Read,Bash,Glob,Grep,Agent,Write,Edit"
    local critique_tools="Read,Glob,Grep,Edit,Write"

    # Check state for resume
    local current_step="clone"
    local repo_session=""
    local critique_session=""
    local critique_passes=0
    if [[ -f "$OUTPUT_DIR/.gleaner-state.json" ]]; then
        local repo_status
        repo_status=$(jq -r --arg r "$repo_name" '.repos[$r].status // "pending"' "$OUTPUT_DIR/.gleaner-state.json")
        if [[ "$repo_status" == "complete" ]]; then
            log_status "[$short_name] Already complete, skipping"
            return 0
        elif [[ "$repo_status" == "in-progress" ]]; then
            current_step=$(jq -r --arg r "$repo_name" '.repos[$r].step' "$OUTPUT_DIR/.gleaner-state.json")
            repo_session=$(jq -r --arg r "$repo_name" '.repos[$r].session_id' "$OUTPUT_DIR/.gleaner-state.json")
            critique_session=$(jq -r --arg r "$repo_name" '.repos[$r].critique_session_id // ""' "$OUTPUT_DIR/.gleaner-state.json")
            critique_passes=$(jq -r --arg r "$repo_name" '.repos[$r].critique_passes' "$OUTPUT_DIR/.gleaner-state.json")
            log_status "[$short_name] Resuming from step: $current_step"
        fi
    fi

    # Build extra args for repo access
    local extra_args=(--add-dir "$clone_path")

    # Step 1: Clone
    if [[ "$current_step" == "clone" ]]; then
        clone_repo "$repo_url" "$clone_path" || return 1
        update_repo_state "$repo_name" "in-progress" "" "initial-analysis" 0 ""
        current_step="initial-analysis"
    fi

    # Step 2: Initial analysis
    if [[ "$current_step" == "initial-analysis" ]]; then
        log_status "[$short_name] Step 1/4: Initial analysis..."
        local prompt
        prompt=$(build_initial_analysis_prompt "$clone_path" "$output_path" "$spec_name")
        repo_session=$(run_claude_fork "$BASE_SESSION_ID" "$prompt" "$analysis_tools" "${extra_args[@]}")
        if [[ -z "$repo_session" || "$repo_session" == "null" ]]; then
            log_error "[$short_name] Initial analysis failed"
            update_repo_state "$repo_name" "failed" "" "initial-analysis" 0 ""
            return 1
        fi
        log_session "$short_name" "=== Initial Analysis ==="
        update_repo_state "$repo_name" "in-progress" "$repo_session" "deep-analysis" 0 ""
        current_step="deep-analysis"
    fi

    # Step 3: Deep analysis
    if [[ "$current_step" == "deep-analysis" ]]; then
        log_status "[$short_name] Step 2/4: Going deeper..."
        local prompt
        prompt=$(build_deep_analysis_prompt "$output_path")
        run_claude_resume "$repo_session" "$prompt" "$analysis_tools" "${extra_args[@]}" >/dev/null
        update_repo_state "$repo_name" "in-progress" "$repo_session" "inversion" 0 ""
        current_step="inversion"
    fi

    # Step 4: Structural inversion
    if [[ "$current_step" == "inversion" ]]; then
        log_status "[$short_name] Step 3/4: Structural inversion..."
        local prompt
        prompt=$(build_inversion_prompt "$repo_name" "$output_path")
        run_claude_resume "$repo_session" "$prompt" "$analysis_tools" "${extra_args[@]}" >/dev/null
        update_repo_state "$repo_name" "in-progress" "$repo_session" "critique" 0 ""
        current_step="critique"
    fi

    # Step 5: Critique loop
    if [[ "$current_step" == "critique" ]]; then
        # Safety check: if resuming but no critique session, restart critique from scratch
        if [[ $critique_passes -gt 0 && -z "$critique_session" ]]; then
            log_status "[$short_name] No critique session found, restarting critique from pass 1..."
            critique_passes=0
        fi

        # First critique pass: fork from base (sheds heavy analysis context)
        if [[ $critique_passes -eq 0 ]]; then
            log_status "[$short_name] Step 4/4: Critique pass 1..."
            local first_prompt
            first_prompt=$(build_first_critique_prompt "$output_path")
            critique_session=$(run_claude_fork "$BASE_SESSION_ID" "$first_prompt" "$critique_tools" "${extra_args[@]}")

            if [[ -z "$critique_session" || "$critique_session" == "null" ]]; then
                log_error "[$short_name] First critique pass failed"
                update_repo_state "$repo_name" "failed" "$repo_session" "critique" 0 ""
                cleanup_repo "$clone_path"
                return 1
            fi

            critique_passes=1
            update_repo_state "$repo_name" "in-progress" "$repo_session" "critique" "$critique_passes" "$critique_session"
        fi

        # Subsequent critique passes: resume from critique session
        local critique_prompt
        critique_prompt=$(build_critique_prompt)

        while [[ $critique_passes -lt $MAX_CRITIQUE_PASSES ]]; do
            critique_passes=$((critique_passes + 1))
            log_status "[$short_name] Step 4/4: Critique pass $critique_passes..."

            local result
            result=$(run_claude_resume "$critique_session" "$critique_prompt" "$critique_tools" "${extra_args[@]}")
            update_repo_state "$repo_name" "in-progress" "$repo_session" "critique" "$critique_passes" "$critique_session"

            if [[ "$(is_cosmetic "$result")" == "true" ]]; then
                log_info "[$short_name] Converged after $critique_passes critique passes"
                break
            fi
        done

        if [[ $critique_passes -ge $MAX_CRITIQUE_PASSES ]]; then
            log_info "[$short_name] Hit max critique passes ($MAX_CRITIQUE_PASSES)"
        fi
    fi

    # Mark complete and clean up
    update_repo_state "$repo_name" "complete" "$repo_session" "critique" "$critique_passes" "$critique_session"
    cleanup_repo "$clone_path"
    log_status "[$short_name] Analysis complete"
    return 0
}

run_parallel_analysis() {
    local pids=()
    local repos_started=0
    local repos_total=${#REPO_URLS[@]}
    local failed_repos=()

    log_status "Phase 4/5: Analyzing $repos_total repos with $WORKERS workers..."
    save_state "deep-dives" ""

    while [[ $repos_started -lt $repos_total ]] || [[ ${#pids[@]} -gt 0 ]]; do
        # Launch workers up to WORKERS limit
        while [[ ${#pids[@]} -lt $WORKERS && $repos_started -lt $repos_total ]]; do
            local url="${REPO_URLS[$repos_started]}"
            repos_started=$((repos_started + 1))
            (
                analyze_repo "$url"
            ) &
            pids+=($!)
        done

        # Wait for any one to finish
        if [[ ${#pids[@]} -gt 0 ]]; then
            local new_pids=()
            for pid in "${pids[@]}"; do
                if kill -0 "$pid" 2>/dev/null; then
                    new_pids+=("$pid")
                else
                    wait "$pid" || failed_repos+=("$pid")
                fi
            done
            if [[ ${#new_pids[@]} -gt 0 ]]; then
                pids=("${new_pids[@]}")
            else
                pids=()
            fi
            # Brief pause to avoid busy-waiting
            [[ ${#pids[@]} -gt 0 ]] && sleep 1
        fi
    done

    if [[ ${#failed_repos[@]} -gt 0 ]]; then
        log_error "${#failed_repos[@]} repo(s) failed analysis"
        return 1
    fi
    return 0
}

build_synthesis_prompt() {
    cat <<EOF
Read all analysis files in ${OUTPUT_DIR}/analysis-*.md. These are
deep analyses of open source projects evaluated against the spec
you read at the start of this conversation.

Synthesize the cross-cutting insights into concrete spec
enhancement recommendations. Focus on:
- Architectural patterns that appear across multiple projects
- Structural advantages the spec has that should be emphasized
- Gaps or blind spots the spec should address
- Ideas that can be combined or reimagined

Write your synthesis to ${OUTPUT_DIR}/synthesis.md.
EOF
}

run_synthesis() {
    log_status "Phase 5/5: Synthesizing cross-cutting insights..."

    local prompt
    prompt=$(build_synthesis_prompt)
    local allowed_tools="Read,Glob,Grep,Write"

    local session_id
    session_id=$(run_claude_fork "$BASE_SESSION_ID" "$prompt" "$allowed_tools")

    if [[ -z "$session_id" || "$session_id" == "null" ]]; then
        log_error "Synthesis session failed"
        return 1
    fi

    log_session "synthesis" "Synthesis session: $session_id"

    # Update state
    local tmp
    tmp=$(mktemp)
    jq '.synthesis = "complete"' "$OUTPUT_DIR/.gleaner-state.json" > "$tmp"
    mv "$tmp" "$OUTPUT_DIR/.gleaner-state.json"

    log_info "Synthesis complete"

    if [[ ! -f "$OUTPUT_DIR/synthesis.md" ]]; then
        log_error "Synthesis did not produce synthesis.md"
        return 1
    fi
}

cleanup_on_exit() {
    local exit_code=$?
    # Save state if we were mid-pipeline
    if [[ -n "$BASE_SESSION_ID" && -d "$OUTPUT_DIR" ]]; then
        log_info "Interrupted. State saved to $OUTPUT_DIR/.gleaner-state.json"
    fi
    # Clean up any remaining cloned repos
    if [[ -d "$CLONE_DIR" ]]; then
        rm -rf "$CLONE_DIR"
    fi
    exit "$exit_code"
}

setup_signal_handlers() {
    trap 'cleanup_on_exit' EXIT
    trap 'exit 10' INT TERM
}

main() {
    if [[ $# -eq 0 ]]; then
        usage
        exit 2
    fi

    case "${1:-}" in
        --help|-h) usage; exit 0 ;;
        --version) echo "gleaner $GLEANER_VERSION"; exit 0 ;;
    esac

    parse_args "$@"
    check_dependencies || exit $?

    mkdir -p "$OUTPUT_DIR"
    setup_logging
    setup_signal_handlers

    # Resolve REPO_URLS
    REPO_URLS=()

    if [[ "$CONTINUE_MODE" == "true" ]]; then
        # Resume from state file or reference-projects.md
        if [[ -f "$OUTPUT_DIR/.gleaner-state.json" ]]; then
            local saved_phase
            saved_phase=$(load_state_field ".phase")
            local saved_base
            saved_base=$(load_state_field ".base_session_id")

            if [[ -n "$saved_base" && "$saved_base" != "null" ]]; then
                BASE_SESSION_ID="$saved_base"
                log_info "Resuming with base session: $BASE_SESSION_ID"
            fi

            if [[ "$saved_phase" == "deep-dives" ]]; then
                # Collect repos from state (resume in-progress and pending)
                while IFS= read -r url; do
                    [[ -n "$url" ]] && REPO_URLS+=("$url")
                done < <(jq -r '.repos | to_entries[] | select(.value.status != "complete") | .key' "$OUTPUT_DIR/.gleaner-state.json" 2>/dev/null | while read -r name; do
                    # Reconstruct URL from name
                    echo "https://github.com/$name"
                done)

                # Also add any not yet in state from reference-projects.md
                if [[ -f "$OUTPUT_DIR/reference-projects.md" ]]; then
                    while IFS= read -r url; do
                        local name
                        name=$(repo_name_from_url "$url")
                        local in_state
                        in_state=$(jq -r --arg r "$name" '.repos[$r].status // "absent"' "$OUTPUT_DIR/.gleaner-state.json")
                        if [[ "$in_state" == "absent" ]]; then
                            REPO_URLS+=("$url")
                        fi
                    done < <(extract_github_urls "$OUTPUT_DIR/reference-projects.md")
                fi
            fi
        elif [[ -f "$OUTPUT_DIR/reference-projects.md" ]]; then
            # No state file — read reference-projects.md (post-checkpoint)
            while IFS= read -r url; do
                [[ -n "$url" ]] && REPO_URLS+=("$url")
            done < <(extract_github_urls "$OUTPUT_DIR/reference-projects.md")
        else
            log_error "No state file or reference-projects.md found. Run without --continue first."
            exit 2
        fi
    elif [[ ${#PRESEEDED_REPOS[@]} -gt 0 ]]; then
        # Pre-seeded repos — skip discovery
        REPO_URLS=("${PRESEEDED_REPOS[@]}")
    fi

    # Phase 1: Create base session (if not resuming with one)
    if [[ -z "$BASE_SESSION_ID" ]]; then
        BASE_SESSION_ID=$(create_base_session "$SPEC_FILE") || exit $?
        save_state "ingestion" ""
    fi

    # If no repos yet, run discovery + checkpoint
    if [[ ${#REPO_URLS[@]} -eq 0 && "$CONTINUE_MODE" != "true" ]]; then
        # Phase 2: Discovery
        run_discovery || exit $?

        # Phase 3: Human checkpoint
        human_checkpoint
        # human_checkpoint calls exit 10, never reaches here
    fi

    # Limit repos
    if [[ ${#REPO_URLS[@]} -gt $MAX_REPOS ]]; then
        log_info "Limiting to $MAX_REPOS repos (from ${#REPO_URLS[@]})"
        REPO_URLS=("${REPO_URLS[@]:0:$MAX_REPOS}")
    fi

    # Phase 4: Parallel deep-dives
    local analysis_failed=false
    run_parallel_analysis || analysis_failed=true

    # Phase 5: Synthesis (even if some repos failed)
    local analysis_count
    analysis_count=$(find "$OUTPUT_DIR" -name "analysis-*.md" 2>/dev/null | wc -l | tr -d ' ')
    if [[ "$analysis_count" -gt 0 ]]; then
        run_synthesis || log_error "Synthesis failed"
    else
        log_error "No analyses produced — skipping synthesis"
    fi

    # Report results
    echo ""
    echo "Gleaner complete."
    echo "  Analyses: $OUTPUT_DIR/analysis-*.md"
    if [[ -f "$OUTPUT_DIR/synthesis.md" ]]; then
        echo "  Synthesis: $OUTPUT_DIR/synthesis.md"
    fi
    echo ""

    if [[ "$analysis_failed" == "true" ]]; then
        exit 1
    fi
    exit 0
}

[[ "${BASH_SOURCE[0]}" == "${0}" ]] && main "$@" || true
